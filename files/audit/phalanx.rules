# Make loginuid immutable. Prevents tampering with the auid.
--loginuid-immutable

# Audit user/group changes
-w /etc/passwd -p wa -k passwd_changes
-w /etc/shadow -p wa -k shadow_changes
-w /etc/group -p wa -k group_changes

# Audit sudo changes
-w /etc/sudoers -p wa -k sudoers_changes
-w /etc/sudoers.d/ -p wa -k sudoers_changes

# Audit ssh config
-w /etc/ssh/sshd_config -p wa -k sshd_config

# Audit root commands
-a always,exit -F arch=b64 -F uid=0 -S execve -k root_cmd

# Audit proxmox
-w /etc/pve/ -p wa -k proxmox_config
-w /etc/corosync/ -p wa -k proxmox_cluster